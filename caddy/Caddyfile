# ── HTTP-only Caddyfile ───────────────────────────────────────────────────────
# Default mode — no TLS required. Works out of the box behind Cloudflare Tunnel
# or any external reverse proxy that handles HTTPS for you.
#
# To use HTTPS with your own certs instead, set in your .env:
#   CADDYFILE=./caddy/Caddyfile.tls
{
    admin off
    auto_https off
}

:{$HTTP_PORT:-8081} {
    request_body {
        max_size 50MB
    }

    # ── PhaseLink WebSocket ───────────────────────────────────────────────────
    @ws {
        path /ws /ws/*
    }
    reverse_proxy @ws phaselink:4000

    # ── LiveKit WebSocket (voice/video) ───────────────────────────────────────
    @livekit {
        path /rtc /rtc/*
    }
    reverse_proxy @livekit livekit:7880

    # ── Everything else → PhaseLink REST API ─────────────────────────────────
    reverse_proxy phaselink:4000

    log {
        output stdout
    }
}
